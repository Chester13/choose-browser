<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <RadioGroup
        android:id="@+id/sort_mode_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Default Sort Option -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <RadioButton
                android:id="@+id/radio_default_sort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/default_sort"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/default_sort_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="4dp"
                android:text="@string/default_sort_description"
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_hidden_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="8dp"
                android:text="@string/hidden_list"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="?android:attr/listDivider" />

        <!-- Custom Sort Option -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <RadioButton
                android:id="@+id/radio_custom_sort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_sort"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/custom_sort_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="4dp"
                android:text="@string/custom_sort_description"
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp" />

        </LinearLayout>

    </RadioGroup>

</LinearLayout>
