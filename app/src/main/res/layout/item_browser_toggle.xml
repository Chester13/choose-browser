<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/browser_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:contentDescription="@string/chooser_item_logo"
        tools:src="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/browser_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:layout_toStartOf="@id/browser_toggle"
        android:layout_toEndOf="@id/browser_icon"
        android:ellipsize="end"
        android:maxLines="1"
        android:textSize="16sp"
        tools:text="Chrome" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/browser_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true" />

</RelativeLayout>
